{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd app && pnpm build",
  "outputDirectory": "app/.next",
  "installCommand": "npx --yes pnpm@10.34.5 install --frozen-lockfile && npx --yes pnpm@10.34.5 --dir app install --frozen-lockfile",
  "framework": "nextjs",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "{api/**,core/**,schema/**,memory/**,sourcing/**,intelligence/**,backtest/**,data/seed/**,data/llm_cache/**,data/sources.json}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" }
  ]
}

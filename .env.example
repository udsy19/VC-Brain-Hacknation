# copy to .env — .env is gitignored, never commit real keys

LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

GITHUB_TOKEN=

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# flip to beta_binomial if the Kalman filter misbehaves (verify the flag works at H10)
SCORE_MODEL=kalman

# Which event store to read. Inferred from DATABASE_URL when unset
# (postgres:// -> postgres, otherwise in-memory). Set explicitly to override.
MEMORY_BACKEND=

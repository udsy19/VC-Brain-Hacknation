.env
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/

node_modules/
.next/
out/

# caches: regenerable, and llm_cache gets large fast
# The LLM completion cache IS COMMITTED, deliberately.
#
# It is 12MB of prompt-hash -> response for the seed corpus, and on Vercel it is the
# difference between a demo and a 504: measured on a read-only simulation, GET /dissent
# takes 10.8s with the cache and 90.8s without it, against maxDuration 60. The memo goes
# 9.0s -> 27.1s. Serverless has no warm disk to rebuild it on, so an ignored cache is a
# cache that never exists in production.
#
# It contains prompts and completions about public evidence only — no keys, no
# credentials, no private data. Checked before committing, and worth re-checking if the
# corpus ever ingests anything non-public.
!data/llm_cache/*
!data/llm_cache/.gitkeep
data/raw/*
!data/raw/.gitkeep

# uploaded decks: founder-supplied binaries, never committed
data/decks/*
!data/decks/.gitkeep

.DS_Store

# local event store (regenerate with scripts/seed.py)
data/*.db
data/*.db-journal

# agent worktrees from other sessions — never part of this repo
.claude/worktrees/

# pre-purge database dumps. These are full-table snapshots and include the users,
# sessions and login_attempts tables — i.e. argon2 password hashes and session token
# hashes. They exist so a destructive corpus edit is recoverable; they must never be
# committed. Keep them locally, or move them somewhere with the same access posture
# as the database itself.
data/backups/

# computed caches — recomputed on demand, and the standout frame key does not
# survive a process restart anyway (see scripts/warm.py), so committing it would
# ship a cache that is already stale.
data/standout_cache/
data/llm_cache_test_untrusted/

# agent working files
scratchpad/
.vercel
.env*
